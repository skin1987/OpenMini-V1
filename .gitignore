# ============================================================
# OpenMini-V1 Project .gitignore
# AI Inference Engine (Rust + Python)
# ============================================================

# ============ Rust 编译产物 ============
/target/
**/*.rs.bk
*.rlib
*.so
*.dylib
*.dll
*.lib
*.a

# Rust 测试和覆盖率
*.profraw
*.profdata
coverage/

# ============ Cargo 相关 ============
Cargo.lock
.cargo/config.toml.local

# ============ Python 相关 ============
__pycache__/
*[!_].py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
*.whl
wheelhouse/
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
mypy_cache/
.ruff_cache/

# ============ GPU 计算相关 ============
# Metal 编译缓存
*.metal-ir
*.air
# CUDA 编译产物
*.ptx
*.cubin
*.fatbin
# Vulkan shader 缓存
*.spv.cache

# ============ 协议缓冲区 ============
*.pb.go
*_grpc.pb.go
openmini-proto/src/generated.rs

# ============ IDE 和编辑器 ============
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project
*.code-workspace

# macOS 系统文件
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows 系统文件
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp

# Linux 系统文件
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ============ 备份和临时文件 ============
*.bk
*.bak
*.tmp
*.temp
*.orig
*.swp
*.swo
*~.nib

# ============ 日志和调试文件 ============
*.log
logs/
debug.log
info.log
error.log
*.trace

# ============ 环境变量和密钥 ============
